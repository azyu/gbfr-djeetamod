{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Djeeta MOD",
    "version": "0.1.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": false,
        "close": true,
        "hide": true,
        "show": true,
        "maximize": true,
        "minimize": true,
        "unmaximize": true,
        "unminimize": true,
        "startDragging": true
      },
      "fs": {
        "readFile": true,
        "scope": ["$RESOURCE/*", "$RESOURCE/lang/*", "$RESOURCE/lang/*/*", "$RESOURCE/assets/*", "$RESOURCE/assets/*/*"]
      },
      "path": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "Djeeta MOD",
        "label": "main",
        "fullscreen": false,
        "width": 330,
        "height": 145,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "minWidth": 280,
        "minHeight": 120,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI --disable-gpu"
      },
      {
        "title": "Djeeta MOD",
        "label": "logs",
        "url": "/logs",
        "fullscreen": false,
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "closable": true,
        "decorations": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI --disable-gpu"
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": ["nsis"],
      "identifier": "com.azyu.djeeta-mod",
      "longDescription": "Unverified test build of Djeeta MOD targeting Granblue Fantasy: Relink 2.0.2",
      "shortDescription": "Djeeta MOD Test Build",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
      "resources": ["hook.dll", "assets/*", "lang/*"],
      "windows": {
        "webviewInstallMode": {
          "type": "embedBootstrapper"
        },
        "nsis": {
          "installMode": "currentUser",
          "installerIcon": "icons/icon.ico"
        }
      }
    },
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "updater": {
      "active": false,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDQjZEMTgxOEY4OTIwNDcKUldSSElJbVBnZEcyM1BSUklxWWRsWStXYnVsWU1mODY3YzZCWCtTZzJrUGJsZHpNY1h1S3hhc2cK",
      "endpoints": [
        "https://raw.githubusercontent.com/onelittlechildawa/gbfr-logs/codex/game-2.0.2-compat/update.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
